# Vercel Environment Variables
# Copy these to Vercel Dashboard → Settings → Environment Variables
# If Vercel env var QUICKBITES_API_URL is set, it will override this value.
# Use a public tunnel URL here only for temporary local-backend testing.

# Production API URL (Render backend)
VITE_API_BASE_URL=https://quickbites-api.onrender.com/api/v1

# Optional: Analytics
VITE_GA_TRACKING_ID=

# Build settings
NODE_VERSION=18
NPM_VERSION=9
